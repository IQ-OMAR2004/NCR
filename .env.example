# Copy to .env for local dev. On Railway, set these as service variables.

# SQLite location. Local: a file in the project. Railway: point at a PERSISTENT
# VOLUME (e.g. mount a volume at /data) so data survives redeploys.
DATABASE_URL="file:./dev.db"
# Railway example (with a volume mounted at /data):
# DATABASE_URL="file:/data/prod.db"

# Session signing secret. MUST be set to a random string of >=16 chars in
# production — the app refuses to start otherwise. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
SESSION_SECRET="change-me-to-a-long-random-string"
